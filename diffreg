library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity reg_setup is
    Port ( 
        clk : in  STD_LOGIC;
        rst : in  STD_LOGIC;
        en  : in  STD_LOGIC;                      -- FSM 控制的「寫入鎖定」訊號
        d   : in  STD_LOGIC_VECTOR(1 downto 0);   -- 3-bit 設定輸入
        q   : out STD_LOGIC_VECTOR(1 downto 0)    -- 3-bit 設定輸出
    );
end reg_setup;

architecture Behavioral of reg_setup is
begin
    process(clk, rst)
    begin
        if rst = '1' then
            q <= "00"; -- 預設 Mode 0, EASY
        elsif rising_edge(clk) then
            if en = '1' then
                q <= d; -- 只有在 en='1' 的瞬間，才把外面的開關狀態「吞」進去鎖死
            end if;
        end if;
    end process;
end Behavioral;
